# Test Environment Variables
# Copy to .env.test and fill in your values

# Database (use test database)
DATABASE_URL="postgresql://postgres:password@localhost:5432/basicllm_test"
DIRECT_URL="postgresql://postgres:password@localhost:5432/basicllm_test"

# Supabase (test project)
SUPABASE_URL="https://test.supabase.co"
SUPABASE_ANON_KEY="test-anon-key"
SUPABASE_SERVICE_ROLE_KEY="test-service-role-key"

# Security (test keys only)
JWT_SECRET="test-jwt-secret-min-32-characters-long"
ENCRYPTION_KEY="test-encryption-key-32chars!!"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Provider API Keys (test keys)
GEMINI_API_KEY=""
GROQ_API_KEY=""

# Rate Limiting (relaxed for tests)
RATE_LIMIT_REQUESTS_PER_MINUTE="1000"
RATE_LIMIT_REQUESTS_PER_HOUR="100000"

# Logging
LOG_LEVEL="debug"
